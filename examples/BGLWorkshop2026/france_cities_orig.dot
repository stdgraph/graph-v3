graph FranceTransport {
    layout=neato;
    overlap=false;
    splines=true;

    Paris -- Lille        [label="225 km"];
    Paris -- Rennes       [label="350 km"];
    Paris -- Nantes       [label="385 km"];
    Paris -- Dijon        [label="315 km"];
    Paris -- Strasbourg   [label="490 km"];

    Rennes -- Nantes      [label="110 km"];

    Nantes -- Bordeaux    [label="345 km"];

    Bordeaux -- Toulouse  [label="245 km"];

    Toulouse -- Montpellier [label="240 km"];
    Toulouse -- Lyon        [label="540 km"];

    Montpellier -- Marseille [label="170 km"];

    Marseille -- Nice     [label="200 km"];
    Marseille -- Lyon     [label="315 km"];

    Nice -- Lyon          [label="470 km"];

    Lyon -- Dijon         [label="195 km"];
    Lyon -- Strasbourg    [label="490 km"];

    Dijon -- Strasbourg   [label="335 km"];
}
